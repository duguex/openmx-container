#!/usr/bin/env python3
"""
omx-gen — Agent-driven OpenMX input file generator.

Combines ASE structure reading + OpenMX writer with keyword schema
and calculation-type templates to produce ready-to-run .dat files.

Usage:
  omx-gen STRUCTURE [options]
  omx-gen --list-templates
  omx-gen --list-keywords
  omx-gen --keyword KEY
"""

import argparse
import json
import os
import sys
from pathlib import Path

# ── Paths relative to this script ────────────────────────────────────
HERE = Path(__file__).resolve().parent
SCHEMA_PATH = HERE / "schemas" / "keywords.json"
TEMPLATES_PATH = HERE / "schemas" / "templates.json"


def load_json(path, name):
    try:
        with open(path) as f:
            return json.load(f)
    except FileNotFoundError:
        print(f"Error: {name} not found at {path}", file=sys.stderr)
        sys.exit(1)


def auto_kgrid(atoms, kspacing):
    """Compute Monkhorst-Pack k-point grid from reciprocal lattice vectors.

    Formula: Nk_i = max(1, floor(|b_i| / kspacing))
    where b_i are the reciprocal lattice basis vectors in 1/Å.
    """
    import numpy as np

    cell = atoms.cell
    # ASE's cell.reciprocal() returns vectors in 1/(2π·Å) — multiply by 2π
    # to get actual reciprocal space vectors in 1/Å.
    recip = cell.reciprocal() * (2 * np.pi)
    lengths = np.linalg.norm(recip, axis=1)
    kgrid = [max(1, int(np.floor(l / kspacing))) for l in lengths]
    return kgrid


def strip_current_directory(dat_path):
    """Remove System.CurrentDirectory — OpenMX defaults to CWD."""
    with open(dat_path) as f:
        lines = f.readlines()
    kept = [l for l in lines if not l.strip().startswith("System.CurrentDirectory")]
    if len(kept) != len(lines):
        with open(dat_path, "w") as f:
            f.writelines(kept)

def to_ase_key(openmx_key, schema):
    """Convert OpenMX dot-style key to ASE snake_case key."""
    if openmx_key in schema:
        entry = schema[openmx_key]
        if entry.get("ase_key"):
            return entry["ase_key"]
    # Fallback: simple underscore conversion
    parts = openmx_key.split(".")
    return "_".join(parts).lower()


def to_openmx_key(ase_key, schema):
    """Reverse lookup: find OpenMX dot-style key for an ASE snake_case key."""
    for omx_k, entry in schema.items():
        if entry.get("ase_key") == ase_key:
            return omx_k
    return None


def generate_input(structure_path, template_name, overrides, schema,
                   templates, kspacing, dry_run, verbose, output_path):
    """Core pipeline: read structure, resolve params, write .dat."""
    from ase.io import read
    from ase.calculators.openmx import OpenMX

    # 1. Read structure
    if verbose:
        print(f"Reading structure: {structure_path}", file=sys.stderr)
    try:
        atoms = read(structure_path)
    except Exception as e:
        print(f"Error reading structure file '{structure_path}': {e}",
              file=sys.stderr)
        sys.exit(1)

    if verbose:
        print(f"  Atoms: {len(atoms)}, formula: {atoms.get_chemical_formula()}",
              file=sys.stderr)

    # 2. Load template
    if template_name not in templates:
        print(f"Error: unknown template '{template_name}'. "
              f"Available: {', '.join(sorted(templates.keys()))}",
              file=sys.stderr)
        sys.exit(1)

    template = templates[template_name]
    params = dict(template["keywords"])  # shallow copy

    if verbose:
        print(f"Using template: {template_name} — "
              f"{template.get('description', '')}", file=sys.stderr)

    # 3. Auto k-points
    if template.get("auto_kpoints") and "kpts" not in overrides:
        kgrid = auto_kgrid(atoms, kspacing)
        params["kpts"] = tuple(kgrid)
        if verbose:
            print(f"  Auto kpts: {tuple(kgrid)} (kspacing={kspacing} 1/Å)",
                  file=sys.stderr)

    # 4. Apply user overrides
    #    Handle special CLI flags first, then --set key=value
    for key, value in overrides.items():
        params[key] = value
        if verbose:
            print(f"  Override: {key} = {value}", file=sys.stderr)

    # 5. Resolve None defaults from schema
    for key in list(params.keys()):
        if params[key] is None:
            # Try schema lookup by ase_key
            for omx_k, entry in schema.items():
                if entry.get("ase_key") == key and entry.get("default") is not None:
                    params[key] = entry["default"]
                    if verbose:
                        print(f"  Schema default: {key} = {entry['default']}",
                              file=sys.stderr)
                    break

    # Resolve DATA.PATH
    if "data_path" not in params or not params.get("data_path"):
        env_path = os.environ.get("OPENMX_DFT_DATA_PATH")
        if env_path:
            params["data_path"] = env_path
            if verbose:
                print(f"  Using OPENMX_DFT_DATA_PATH: {env_path}",
                      file=sys.stderr)
        else:
            bundled = HERE / "openmx4.0" / "DFT_DATA19"
            if bundled.is_dir():
                params["data_path"] = str(bundled.resolve())
                if verbose:
                    print(f"  Using bundled DFT_DATA19: {bundled}",
                          file=sys.stderr)
            else:
                print("Error: DATA.PATH not set and no DFT_DATA19 found in openmx4.0/.",
                      file=sys.stderr)
                print("  Set OPENMX_DFT_DATA_PATH to your DFT_DATA19 directory.",
                      file=sys.stderr)
                print("  Download from: https://www.openmx-square.org/download.html",
                      file=sys.stderr)
                sys.exit(1)

    # Pre-flight: verify VPS dir exists (ASE's writer reads it)
    data_path = params["data_path"]
    vps_dir = os.path.join(data_path, "VPS")
    if not os.path.isdir(vps_dir):
        print(f"Error: VPS directory not found at {vps_dir}", file=sys.stderr)
        print("  DATA.PATH =", data_path, file=sys.stderr)
        sys.exit(1)

    # 6. Generate output stem from output path
    if output_path:
        stem = Path(output_path).stem
    else:
        stem = Path(structure_path).stem

    # 7. Write input via ASE calculator
    if dry_run:
        import tempfile
        with tempfile.TemporaryDirectory() as tmpdir:
            calc = OpenMX(label=os.path.join(tmpdir, stem),
                          command="", **params)
            calc.write_input(atoms)
            dat_path = os.path.join(tmpdir, f"{stem}.dat")
            with open(dat_path) as f:
                content = f.read()
        # Strip absolute System.CurrentDirectory
        content = "\n".join(
            l for l in content.split("\n")
            if not l.strip().startswith("System.CurrentDirectory")
        )
        sys.stdout.write(content)
        if verbose:
            print("(dry-run: printed to stdout)", file=sys.stderr)
    else:
        out_path = output_path or f"{stem}.dat"
        calc = OpenMX(label=os.path.join(os.getcwd(), stem),
                      command="", **params)
        calc.write_input(atoms)
        written = f"{stem}.dat"
        if os.path.abspath(written) != os.path.abspath(out_path):
            os.rename(written, out_path) if os.path.exists(written) else None
        strip_current_directory(out_path)
        if verbose:
            print(f"Written: {out_path}", file=sys.stderr)

    return params


def list_templates(templates):
    """Print available templates."""
    print("Available templates:")
    for name, t in sorted(templates.items()):
        auto = " [auto-kpoints]" if t.get("auto_kpoints") else ""
        prior = " [requires prior SCF]" if t.get("requires_prior_scf") else ""
        desc = t.get("description", "")
        print(f"  {name}{auto}{prior}")
        if desc:
            print(f"        {desc}")
        for key, val in t["keywords"].items():
            val_str = json.dumps(val) if val is not None else "auto"
            print(f"          {key} = {val_str}")


def list_keywords(schema):
    """Print all known keywords with type info."""
    print("Known keywords:")
    for kw, entry in sorted(schema.items()):
        if entry["type"]:
            print(f"  {kw}  [{entry['type']}]", end="")
            if entry.get("default"):
                print(f"  default={entry['default']}", end="")
            if entry.get("unit"):
                print(f"  ({entry['unit']})", end="")
            print()
        else:
            print(f"  {kw}  [untyped — manual section keyword]")


def show_keyword(kw, schema):
    """Show structured metadata for a single keyword."""
    if kw not in schema:
        print(f"Keyword '{kw}' not found in schema.", file=sys.stderr)
        sys.exit(1)
    entry = schema[kw]
    print(f"{kw}:")
    print(f"  type:        {entry.get('type', 'null')}")
    print(f"  ase_key:     {entry.get('ase_key', 'null')}")
    print(f"  default:     {json.dumps(entry.get('default'))}")
    print(f"  valid:       {json.dumps(entry.get('valid_values'))}")
    print(f"  unit:        {json.dumps(entry.get('unit'))}")
    print(f"  section:     {entry.get('section', 'null')}")
    print(f"  source:      {entry.get('source', 'null')}")
    desc = entry.get("description")
    if desc:
        print(f"  description: {desc}")


def parse_set_overrides(set_args, schema):
    """Parse --set KEY=VALUE arguments into ASE-style dict."""
    overrides = {}
    for arg in set_args:
        if "=" not in arg:
            print(f"Warning: --set '{arg}' missing '=' sign, skipping",
                  file=sys.stderr)
            continue
        key, _, raw_val = arg.partition("=")
        key = key.strip()
        raw_val = raw_val.strip()

        # Try converting value
        # First check if it's a known OpenMX keyword
        ase_key = to_ase_key(key, schema)

        # Try numeric conversion
        try:
            if "." in raw_val or "e" in raw_val.lower():
                val = float(raw_val)
            else:
                val = int(raw_val)
        except (ValueError, TypeError):
            val = raw_val  # keep as string

        overrides[ase_key] = val
    return overrides


def parse_args():
    parser = argparse.ArgumentParser(
        description="Generate OpenMX .dat input files from structure + templates",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  omx-gen structure.cif -t scf_band -o Si.dat\n"
            "  omx-gen mol.xyz -t scf_cluster --kspacing 0.25 -v\n"
            "  omx-gen POSCAR -t geom_opt -x LDA --set 'scf.SpinPolarization=On'\n"
            "  omx-gen --list-templates\n"
        ),
    )
    parser.add_argument("structure", nargs="?", help="Input structure file (CIF, XYZ, POSCAR, ...)")
    parser.add_argument("-t", "--template", default="scf_band",
                        help="Calculation template (default: scf_band)")
    parser.add_argument("-o", "--output", help="Output .dat file")
    parser.add_argument("--list-templates", action="store_true",
                        help="List available templates")
    parser.add_argument("--list-keywords", action="store_true",
                        help="List all known keywords with type info")
    parser.add_argument("--keyword", metavar="KEY",
                        help="Show structured metadata for a single keyword")
    parser.add_argument("-k", "--kpoints", type=int, nargs=3,
                        metavar=("NX", "NY", "NZ"),
                        help="Override k-point grid")
    parser.add_argument("--kspacing", type=float, default=0.33,
                        help="k-point spacing in 1/Å (default: 0.33)")
    parser.add_argument("-x", "--xc", help="Override XC functional (PBE, LDA, etc.)")
    parser.add_argument("--spin", help="Override spin: Off | On | NC")
    parser.add_argument("--cutoff", type=float, help="Override energy cutoff (eV)")
    parser.add_argument("-s", "--set", action="append", default=[],
                        metavar="KEY=VALUE",
                        help="Set an arbitrary OpenMX keyword")
    parser.add_argument("-d", "--dry-run", action="store_true",
                        help="Print to stdout instead of writing file")
    parser.add_argument("-v", "--verbose", action="store_true",
                        help="Show keyword resolution")
    return parser.parse_args()


def main():
    args = parse_args()

    schema = load_json(SCHEMA_PATH, "keywords.json")
    templates = load_json(TEMPLATES_PATH, "templates.json")

    # Listing/query modes
    if args.list_templates:
        list_templates(templates)
        return
    if args.list_keywords:
        list_keywords(schema)
        return
    if args.keyword:
        show_keyword(args.keyword, schema)
        return

    # Ensure structure file given
    if not args.structure:
        print("Error: STRUCTURE file is required. Use --help for usage.",
              file=sys.stderr)
        sys.exit(1)

    if not os.path.isfile(args.structure):
        print(f"Error: structure file '{args.structure}' not found.",
              file=sys.stderr)
        sys.exit(1)

    # Build overrides dict
    overrides = parse_set_overrides(args.set, schema)

    # Special CLI flag overrides
    if args.kpoints:
        overrides["kpts"] = tuple(args.kpoints)
    if args.xc:
        overrides["scf_xctype"] = args.xc
    if args.spin:
        overrides["scf_spinpolarization"] = args.spin
    if args.cutoff:
        overrides["energy_cutoff"] = args.cutoff

    generate_input(
        structure_path=args.structure,
        template_name=args.template,
        overrides=overrides,
        schema=schema,
        templates=templates,
        kspacing=args.kspacing,
        dry_run=args.dry_run,
        verbose=args.verbose,
        output_path=args.output,
    )


if __name__ == "__main__":
    main()
