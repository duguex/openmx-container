#
# File Name
#

System.CurrrentDir    ./             # default=./
System.Name            N6.0_1s
Log.print              OFF           # ON|OFF

System.UseRestartfile  yes           # NO|YES, default=NO
System.Restartfile     N6.0_1s       # default=null

#
# Calculation type
#

eq.type              sdirac          # sch|sdirac|dirac 
calc.type             pao            # ALL|VPS|PAO
xc.type               GGA            # LDA|GGA

#
# Atom
#

AtomSpecies             7
max.occupied.N          2
total.electron         7.0
valence.electron       7.0 
<occupied.electrons 
 1   2.0
 2   2.0  3.0
occupied.electrons>


#
# parameters for solving 1D-differential equations
#

grid.xmin             -7.6           # default=-7.0 rmin(a.u.)=exp(grid.xmin)
grid.xmax              2.8           # default= 2.5 rmax(a.u.)=exp(grid.xmax)
grid.num              9000           # default=4000
grid.num.output        500           # default=2000

#
# SCF
#

scf.maxIter             60           # default=40            
scf.Mixing.Type       Simple         # Simple|GR-Pulay 
scf.Init.Mixing.Weight 0.10          # default=0.300 
scf.Min.Mixing.Weight  0.001         # default=0.001 
scf.Max.Mixing.Weight  0.800         # default=0.800 
scf.Mixing.History      7            # default=5
scf.Mixing.StartPulay   4            # default=6
scf.criterion         1.0e-13        # default=1.0e-9

#
# Pseudo potetial, cutoff (A.U.)
#

vps.type               MBK           # BHS|TM        
number.vps              4
<pseudo.NandL
